---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundation
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-base-200 bg-white">
  <Wrapper variant="standard" class="py-12">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-5 items-start">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <Logo class="text-base-900 text-lg" />
        <p class="mt-4 text-xs text-base-500 leading-relaxed max-w-sm">
          Offizieller Schüco Partner. Premium-Aluminium Fenster und Türen für Spanien und Italien — energieeffizient, sicher, individuell.
        </p>
        <div class="mt-4 inline-flex items-center gap-1.5 bg-[#1c69d4]/10 text-[#1c69d4] text-xs font-medium px-3 py-1 rounded">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
          Schüco Zertifizierter Partner
        </div>
        <div class="mt-4 flex gap-3">
          <a href="https://www.linkedin.com/company/fenstervertrieb" target="_blank" rel="noopener noreferrer" class="text-base-400 hover:text-[#1c69d4] transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.instagram.com/fenstervertrieb" target="_blank" rel="noopener noreferrer" class="text-base-400 hover:text-[#1c69d4] transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Produkte column -->
      <nav role="navigation">
        <h3 class="text-sm font-medium text-base-900">Produkte</h3>
        <ul class="mt-4 text-xs space-y-3">
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/aws-70-hi">AWS 70.HI Fenster</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/aws-90-si-plus">AWS 90.SI+ Premium</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/ads-90">ADS 90 Türen</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/ass-77-pd-hi">ASS 77 PD.HI Schiebe</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte">Alle Produkte →</a></li>
        </ul>
      </nav>

      <!-- Unternehmen column -->
      <nav role="navigation">
        <h3 class="text-sm font-medium text-base-900">Unternehmen</h3>
        <ul class="mt-4 text-xs space-y-3">
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/ueber-uns">Über uns</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/showrooms">Showrooms</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/foerderungen">Förderungen</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/referenzen">Referenzen</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/konfigurator">Konfigurator</a></li>
        </ul>
      </nav>

      <!-- Kontakt column -->
      <div>
        <h3 class="text-sm font-medium text-base-900">Kontakt</h3>
        <ul class="mt-4 text-xs space-y-3">
          <li class="text-base-500">Avda. de la Libertad 42</li>
          <li class="text-base-500">30009 Murcia, Spanien</li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="mailto:info@fenstervertrieb.com">info@fenstervertrieb.com</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="tel:+34968000000">+34 968 000 000</a></li>
          <li class="text-base-400 mt-2">Mo – Fr: 9:00 – 18:00</li>
        </ul>
        <a
          href="/kontakt"
          class="mt-4 inline-block bg-[#1c69d4] text-white text-xs font-medium px-4 py-2 rounded hover:bg-[#1557b0] transition-colors"
        >
          Beratung anfragen →
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-base-200 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-base-500">
      <span>&copy; {currentYear} Fenstervertrieb GmbH. Alle Rechte vorbehalten.</span>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <a href="/impressum" class="hover:text-base-900 transition-colors">Impressum</a>
        <a href="/agb" class="hover:text-base-900 transition-colors">AGB</a>
        <a href="/datenschutz" class="hover:text-base-900 transition-colors">Datenschutz</a>
        <button id="cookie-settings-btn" class="hover:text-base-900 transition-colors cursor-pointer">Cookie-Einstellungen</button>
      </div>
    </div>
  </Wrapper>
</footer>

<script>
  document.getElementById('cookie-settings-btn')?.addEventListener('click', () => {
    alert('Cookie-Einstellungen werden in Kürze verfügbar sein.');
  });
</script>