---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundation
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-base-200 bg-white">
  <!-- Trust Bar -->
  <Wrapper variant="standard">
    <div class="py-8 border-b border-base-200">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <!-- Schüco Partner -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-[#1c69d4]/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[#1c69d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-base-900">Schüco Partner</div>
            <div class="text-xs text-base-400">Zertifiziert seit 2020</div>
          </div>
        </div>

        <!-- Trusted Shops -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-base-900">Geprüfter Shop</div>
            <div class="text-xs text-base-400">Trusted Shops Garantie</div>
          </div>
        </div>

        <!-- 10+ Jahre Erfahrung -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-base-900">10+ Jahre</div>
            <div class="text-xs text-base-400">Erfahrung am Markt</div>
          </div>
        </div>

        <!-- Europa-weit -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.487V21a1 1 0 01-1 1h-4a1 1 0 01-1-1v-.513c0-1.656 1.344-3 3-3s3 1.344 3 3z"></path>
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-base-900">Deutschland</div>
            <div class="text-xs text-base-400">Lokale Beratung vor Ort</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bewertungen -->
    <div class="py-8 border-b border-base-200">
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <div class="flex items-center gap-2">
          <!-- Sterne -->
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            ))}
          </div>
          <span class="text-sm font-semibold text-base-900">4.9 / 5.0</span>
        </div>
        <div class="text-xs text-base-400">
          Basierend auf <strong class="text-base-600">127 Bewertungen</strong> · Google Bewertungen
        </div>
        <a
          href="https://www.google.com/maps/place/Fenstervertrieb"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-[#1c69d4] hover:underline font-medium ml-auto"
        >
          Alle Bewertungen ansehen →
        </a>
      </div>
    </div>

    <!-- Zahlungsarten -->
    <div class="py-6 border-b border-base-200">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <span class="text-xs text-base-400 font-medium">Zahlungsarten:</span>
        <div class="flex items-center gap-4">
          <!-- Visa -->
          <svg class="h-7 w-auto text-base-300" viewBox="0 0 48 32" fill="currentColor" aria-label="Visa">
            <rect rx="4" width="48" height="32" fill="none"/>
            <path d="M19.2 21.6h-3.1l1.9-11.2h3.1l-1.9 11.2zm13.5-10.9c-.6-.2-1.6-.5-2.8-.5-3.1 0-5.3 1.6-5.3 3.9 0 1.7 1.5 2.6 2.7 3.2 1.2.6 1.6 1 1.6 1.5 0 .8-1 1.2-1.9 1.2-1.3 0-1.9-.2-2.9-.6l-.4-.2-.4 2.6c.7.3 2.1.6 3.5.6 3.3 0 5.4-1.6 5.4-4 0-1.3-.8-2.3-2.7-3.2-1.1-.5-1.8-1-1.8-1.5 0-.5.6-1 1.8-1 1 0 1.8.2 2.4.5l.3.1.3-2.7zm5.1 0h-2.4c-.7 0-1.3.2-1.6.9l-4.5 10.3h3.2l.6-1.7h3.9l.4 1.7h2.8l-2.4-11.2zm-3.8 7.2l1.2-3.2.4-1.1.3 1 .7 3.3h-2.6zM15 10.4l-2.9 7.6-.3-1.5c-.5-1.8-2.2-3.7-4.1-4.7l2.7 9.8h3.3l4.9-11.2H15z" fill="currentColor"/>
            <path d="M9.5 10.4H4.6l0 .2c3.8.9 6.3 3.2 7.3 5.9L10.8 11c-.2-.7-.7-.9-1.3-.6z" fill="currentColor" opacity=".6"/>
          </svg>
          <!-- Mastercard -->
          <svg class="h-7 w-auto text-base-300" viewBox="0 0 48 32" fill="none" aria-label="Mastercard">
            <circle cx="18" cy="16" r="9" fill="currentColor" opacity=".7"/>
            <circle cx="30" cy="16" r="9" fill="currentColor" opacity=".4"/>
          </svg>
          <!-- PayPal -->
          <svg class="h-7 w-auto text-base-300" viewBox="0 0 48 32" fill="currentColor" aria-label="PayPal">
            <path d="M34 11.5c-.3 2-1.7 2-3.1 2h-.8l.6-3.6c0-.1.1-.2.2-.2h.4c.9 0 1.8 0 2.3.5.3.3.4.7.4 1.3zm-1-5h-5.2c-.4 0-.7.3-.8.7l-2.1 13.3c0 .3.2.5.4.5h2.7c.4 0 .7-.3.8-.7l.6-3.6c0-.4.4-.7.8-.7h1.6c3.4 0 5.3-1.6 5.8-4.9.2-1.4 0-2.5-.7-3.3-.7-.8-2-1.3-3.9-1.3zm-13.3 5c-.3.2-2 .6-2-.2.1-.5 1.4-.6 2-.5zm2.8-2.2c-.5-.2-1.3-.3-2.3-.3-2.5 0-4.3 1.3-4.3 3.1 0 1.4 1.3 1.7 2 1.9.7.2 1.3.4 1.3 1 0 .6-.7.9-1.4.9-.9 0-1.4-.1-2.2-.5l-.3-.1-.3 2c.5.2 1.5.5 2.6.5 2.7 0 4.4-1.3 4.4-3.2 0-1.1-.7-1.8-2.1-2.3-.8-.3-1.5-.5-1.5-1 0-.5.5-.8 1.3-.8.7 0 1.3.2 1.7.3l.1.1.4-2z" fill="currentColor"/>
          </svg>
          <!-- Überweisung / Bank -->
          <svg class="h-7 w-auto text-base-300" viewBox="0 0 48 32" fill="currentColor" aria-label="Banküberweisung">
            <path d="M24 6l16 8H8l16-8zm0 2.5L13 14h22L24 8.5zM10 16h28v2H10v-2zm2 4h24v8H12v-8zm2 2v4h4v-4h-4zm6 0v4h4v-4h-4zm6 0v4h4v-4h-4zm6 0v4h4v-4h-4z" fill="currentColor"/>
          </svg>
        </div>
      </div>
    </div>
  </Wrapper>

  <!-- Newsletter Anmeldung -->
  <Wrapper variant="standard" class="pt-10 pb-0">
    <div class="max-w-xl mx-auto text-center lg:text-left lg:mx-0">
      <h3 class="text-lg font-bold text-base-900">Newsletter</h3>
      <p class="mt-1 text-sm text-base-500">Bleiben Sie informiert</p>
      <form class="mt-4 flex gap-3" onsubmit="event.preventDefault();">
        <input
          type="email"
          placeholder="Ihre E-Mail"
          required
          class="flex-1 rounded border border-base-200 bg-white px-4 py-2 text-sm text-base-900 placeholder:text-base-300 focus:border-[#1c69d4] focus:outline-none focus:ring-1 focus:ring-[#1c69d4] transition-colors"
        />
        <button
          type="submit"
          class="shrink-0 rounded bg-[#1c69d4] px-5 py-2 text-sm font-medium text-white hover:bg-[#1557b0] transition-colors"
        >
          Abonnieren
        </button>
      </form>
    </div>
  </Wrapper>

  <!-- Main Footer -->
  <Wrapper variant="standard" class="py-12">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-5 items-start">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <Logo class="text-base-900 text-lg" />
        <p class="mt-4 text-xs text-base-500 leading-relaxed max-w-sm">
          Offizieller Schüco Partner. Premium-Aluminium Fenster und Türen für Deutschland — energieeffizient, sicher, individuell.
        </p>
        <div class="mt-4 flex gap-3">
          <a href="https://www.linkedin.com/company/fenstervertrieb" target="_blank" rel="noopener noreferrer" class="text-base-400 hover:text-[#1c69d4] transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.instagram.com/fenstervertrieb" target="_blank" rel="noopener noreferrer" class="text-base-400 hover:text-[#1c69d4] transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Produkte column -->
      <nav role="navigation">
        <h3 class="text-sm font-medium text-base-900">Produkte</h3>
        <ul class="mt-4 text-xs space-y-3">
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/aws-70-hi">AWS 70.HI Fenster</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/aws-90-si-plus">AWS 90.SI+ Premium</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/ads-90">ADS 90 Türen</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte/ass-77-pd-hi">ASS 77 PD.HI Schiebe</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/produkte">Alle Produkte →</a></li>
        </ul>
      </nav>

      <!-- Unternehmen column -->
      <nav role="navigation">
        <h3 class="text-sm font-medium text-base-900">Unternehmen</h3>
        <ul class="mt-4 text-xs space-y-3">
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/ueber-uns">Über uns</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/showrooms">Showrooms</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/foerderungen">Förderungen</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/referenzen">Referenzen</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="/konfigurator">Konfigurator</a></li>
        </ul>
      </nav>

      <!-- Kontakt column -->
      <div>
        <h3 class="text-sm font-medium text-base-900">Kontakt</h3>
        <ul class="mt-4 text-xs space-y-3">
          <li class="text-base-500">Burscheider Str. 157</li>
          <li class="text-base-500">51381 Leverkusen, Deutschland</li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="mailto:info@fenstervertrieb.de">info@fenstervertrieb.de</a></li>
          <li><a class="text-base-500 hover:text-base-900 transition-colors" href="tel:+49214XXXXXXX">+49 214 XXX XXXX</a></li>
          <li>
            <a class="inline-flex items-center gap-1.5 text-base-500 hover:text-green-600 transition-colors" href="https://wa.me/49214XXXXXXX" target="_blank" rel="noopener noreferrer">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.981.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <span>+49 214 XXX XXXX</span>
            </a>
          </li>
          <li class="text-base-400 mt-2">Mo – Fr: 9:00 – 18:00</li>
        </ul>
        <a
          href="/kontakt"
          class="mt-4 inline-block bg-[#1c69d4] text-white text-xs font-medium px-4 py-2 rounded hover:bg-[#1557b0] transition-colors"
        >
          Beratung anfragen →
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-base-200 text-xs text-base-500">
      <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-between">
        <span>&copy; {currentYear} Fenstervertrieb GmbH. Alle Rechte vorbehalten.</span>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
          <a href="/impressum" class="hover:text-base-900 transition-colors">Impressum</a>
          <a href="/agb" class="hover:text-base-900 transition-colors">AGB</a>
          <a href="/datenschutz" class="hover:text-base-900 transition-colors">Datenschutz</a>
          <button id="cookie-settings-btn" class="hover:text-base-900 transition-colors cursor-pointer">Cookie-Einstellungen</button>
        </div>
      </div>
    </div>
  </Wrapper>
</footer>

<!-- Cookie Banner Stub -->
<div id="cookie-banner" class="fixed bottom-0 inset-x-0 z-50 hidden">
  <div class="mx-auto max-w-4xl bg-white border border-base-200 rounded-lg shadow-lg m-4 p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <p class="text-sm text-base-700 flex-1">
      Diese Website verwendet Cookies, um Ihnen die bestmögliche Erfahrung zu bieten.
      <a href="/datenschutz" class="text-[#1c69d4] hover:underline">Mehr erfahren</a>
    </p>
    <div class="flex gap-3 shrink-0">
      <button id="cookie-accept" class="rounded bg-[#1c69d4] px-4 py-2 text-sm font-medium text-white hover:bg-[#1557b0] transition-colors">Akzeptieren</button>
      <button id="cookie-decline" class="rounded border border-base-200 px-4 py-2 text-sm font-medium text-base-700 hover:bg-base-50 transition-colors">Ablehnen</button>
    </div>
  </div>
</div>

<script>
  const cookieBtn = document.getElementById('cookie-settings-btn');
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  // Show banner on first visit
  if (!localStorage.getItem('cookie_consent')) {
    banner?.classList.remove('hidden');
  }

  cookieBtn?.addEventListener('click', () => {
    banner?.classList.remove('hidden');
  });

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookie_consent', 'accepted');
    banner?.classList.add('hidden');
  });

  declineBtn?.addEventListener('click', () => {
    localStorage.setItem('cookie_consent', 'declined');
    banner?.classList.add('hidden');
  });
</script>