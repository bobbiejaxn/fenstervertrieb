    "Offizieller Schüco Partner für Premium-Fenster und Türen in Deutschland. Schüco Aluminium-Systeme mit höchster Energieeffizienz.",
  telephone: "+49 173 1001726",
  email: "info@fenstervertrieb.de",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Burscheider Str. 157",
    addressLocality: "Leverkusen",
    postalCode: "51381",
    addressCountry: "DE",
    addressRegion: "Nordrhein-Westfalen",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 51.045,
    longitude: 7.008,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
