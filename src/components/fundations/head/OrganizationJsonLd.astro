    },
  ],
  sameAs: [
    "https://www.linkedin.com/company/fenstervertrieb",
    "https://www.instagram.com/fenstervertrieb",
  ],
  brand: {
    "@type": "Brand",
    name: "Schüco",
  },
  priceRange: "€€",
  areaServed: {
    "@type": "Country",
    name: "Germany",
  },
  knowsAbout: [
    "Aluminium-Fenster",
    "Energiesparende Fenster",
    "Schüco Systeme",
    "Hebeschiebetüren",
    "Fassadensysteme",
    "Smart-Home-Gebäudetechnik",
  ],
