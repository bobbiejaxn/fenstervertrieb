  "@type": ["LocalBusiness", "Organization"],
  name: "Fenstervertrieb GmbH",
  url: ORIGIN,
  logo: `${ORIGIN}/images/hero-building.jpg`,
  image: `${ORIGIN}/images/hero-building.jpg`,
