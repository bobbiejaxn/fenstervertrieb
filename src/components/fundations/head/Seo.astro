---

import { AstroSeo } from "@lexingtonthemes/seo";

const { title = "Fenstervertrieb GmbH — Fenster. Türen. Perfektion.", description = "Offizieller Schüco Partner für Premium-Fenster und Türen in Deutschland. Schüco Aluminium-Systeme mit höchster Energieeffizienz." } = Astro.props;
---

<AstroSeo
  title={title}
  description={description}
  canonical={Astro.url.href}
  openGraph={{
    url: Astro.url.href,
    title: title,
    description: description,
    images: [
      {
        url: "/images/hero-building.jpg",
        width: 1200,
        height: 630,
        alt: "Fenstervertrieb — Premium Schüco Systeme",
        type: "image/jpeg",
      },
    ],
    site_name: "Fenstervertrieb GmbH",
    type: "website",
    locale: "de_DE",
  }}
  twitter={{
    handle: "@fenstervertrieb",
    site: "@fenstervertrieb",
    cardType: "summary_large_image",
  }}
/>