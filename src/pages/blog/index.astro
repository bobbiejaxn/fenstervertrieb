---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BreadcrumbJsonLd from "@/components/fundations/head/BreadcrumbJsonLd.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
// Sort by date descending
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog — Fenstervertrieb" description="Fachwissen und Ratgeber rund um Schüco Aluminium-Fenster, Energieeffizienz, Förderungen und mehr.">
  <BreadcrumbJsonLd items={[{ name: "Blog & Ratgeber" }]} />
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
        Blog &amp; Ratgeber
      </h1>
      <p class="mt-4 text-gray-400 max-w-xl">
        Fachartikel, Ratgeber und Tipps rund um Schüco Aluminium-Fenster, Energieeffizienz, Förderungen und smarte Gebäudetechnik.
      </p>
    </Wrapper>
  </section>

  <section class="bg-white">
    <Wrapper variant="standard" class="py-12">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/posts/${post.id}`}
            class="group block"
          >
            <div class="aspect-[16/9] bg-gray-100 overflow-hidden rounded-lg">
              <img
                src={post.data.image.url}
                alt={post.data.image.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="mt-4">
              <div class="flex items-center gap-2 text-xs text-base-500">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                <span>·</span>
                <span>{post.data.author}</span>
              </div>
              <h2 class="mt-2 font-medium text-base-900 group-hover:text-[#1c69d4] transition-colors line-clamp-2">
                {post.data.title}
              </h2>
              <p class="mt-2 text-sm text-base-500 line-clamp-3">
                {post.data.description}
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-center text-base-500 py-12">
          Noch keine Beiträge vorhanden.
        </p>
      )}
    </Wrapper>
  </section>
</BaseLayout>