---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout title="Kontakt — Fenstervertrieb" description="Kontaktieren Sie uns für eine persönliche Beratung. Showrooms in Murcia und Catania.">
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
        Kontakt
      </h1>
      <p class="mt-4 text-gray-400 max-w-xl">
        Nehmen Sie Kontakt mit uns auf. Wir beraten Sie gerne zu unseren Schüco Systemen und Fördermöglichkeiten.
      </p>
    </Wrapper>
  </section>

  <section class="bg-white">
    <Wrapper variant="standard" class="py-12">
      <div class="grid gap-12 md:grid-cols-2">
        <!-- Contact Form -->
        <div>
          <h2 class="font-serif italic text-2xl text-base-900 font-medium">
            Nachricht senden
          </h2>
          <form class="mt-6 space-y-4" action="#" method="POST">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="firstName" class="block text-sm font-medium text-base-700 mb-1">Vorname</label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                  required
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-base-700 mb-1">Nachname</label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                  required
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-base-700 mb-1">E-Mail</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                required
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-base-700 mb-1">Telefon</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-base-700 mb-1">Betreff</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
              >
                <option value="">Bitte wählen...</option>
                <option value="beratung">Produktberatung</option>
                <option value="angebot">Angebot anfragen</option>
                <option value="foerderung">Förderberatung</option>
                <option value="service">Kundenservice</option>
                <option value="sonstiges">Sonstiges</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-base-700 mb-1">Nachricht</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                required
              ></textarea>
            </div>
            <button
              type="submit"
              class="bg-[#1c69d4] text-white px-6 py-3 rounded text-sm font-medium hover:bg-[#1557b0] transition-colors"
            >
              Nachricht senden
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="font-serif italic text-2xl text-base-900 font-medium">
            Kontaktdaten
          </h2>
          <div class="mt-6 space-y-6">
            <div>
              <h3 class="text-sm font-medium text-base-900">Fenstervertrieb GmbH</h3>
              <div class="mt-2 space-y-2">
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <span>Avda. de la Libertad 42, 30009 Murcia, Spanien</span>
                </div>
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  <a href="tel:+34968000000" class="hover:text-[#1c69d4]">+34 968 000 000</a>
                </div>
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <a href="mailto:info@fenstervertrieb.com" class="hover:text-[#1c69d4]">info@fenstervertrieb.com</a>
                </div>
              </div>
            </div>

            <div class="pt-4 border-t border-base-200">
              <h3 class="text-sm font-medium text-base-900">Showroom Catania</h3>
              <div class="mt-2 space-y-2">
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <span>Via dei Liotru 12, 95100 Catania, Italien</span>
                </div>
              </div>
            </div>

            <div class="pt-4 border-t border-base-200">
              <h3 class="text-sm font-medium text-base-900">Öffnungszeiten</h3>
              <div class="mt-2 text-sm text-base-500 space-y-1">
                <p>Montag – Freitag: 9:00 – 18:00</p>
                <p>Samstag: 10:00 – 14:00</p>
                <p>Sonntag: Geschlossen</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>