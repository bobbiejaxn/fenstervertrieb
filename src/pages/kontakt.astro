---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BreadcrumbJsonLd from "@/components/fundations/head/BreadcrumbJsonLd.astro";
---

<BaseLayout title="Kontakt — Fenstervertrieb" description="Kontaktieren Sie uns für eine persönliche Beratung in unserem Showroom in Leverkusen.">
  <BreadcrumbJsonLd items={[{ name: "Kontakt" }]} />
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
        Kontakt
      </h1>
      <p class="mt-4 text-gray-400 max-w-xl">
        Nehmen Sie Kontakt mit uns auf. Wir beraten Sie gerne zu unseren Schüco Systemen und Fördermöglichkeiten.
      </p>
    </Wrapper>
  </section>

  <section class="bg-white">
    <Wrapper variant="standard" class="py-12">
      <div class="grid gap-12 md:grid-cols-2">
        <!-- Contact Form -->
        <div>
          <h2 class="font-serif italic text-2xl text-base-900 font-medium">
            Nachricht senden
          </h2>
          <!-- Form submits via mailto: opens user's email client (serverless alternative to Formspree) -->
          <form class="mt-6 space-y-4" action="mailto:info@fenstervertrieb.de" method="POST" enctype="text/plain">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="firstName" class="block text-sm font-medium text-base-700 mb-1">Vorname</label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                  required
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-base-700 mb-1">Nachname</label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                  required
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-base-700 mb-1">E-Mail</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                required
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-base-700 mb-1">Telefon</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-base-700 mb-1">Betreff</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
              >
                <option value="">Bitte wählen...</option>
                <option value="beratung">Produktberatung</option>
                <option value="angebot">Angebot anfragen</option>
                <option value="foerderung">Förderberatung</option>
                <option value="service">Kundenservice</option>
                <option value="sonstiges">Sonstiges</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-base-700 mb-1">Nachricht</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full px-3 py-2 border border-base-200 rounded text-sm focus:outline-none focus:border-[#1c69d4]"
                required
              ></textarea>
            </div>
            <button
              type="submit"
              class="bg-[#1c69d4] text-white px-6 py-3 rounded text-sm font-medium hover:bg-[#1557b0] transition-colors"
            >
              Nachricht senden
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="font-serif italic text-2xl text-base-900 font-medium">
            Kontaktdaten
          </h2>
          <div class="mt-6 space-y-6">
            <div>
              <h3 class="text-sm font-medium text-base-900">Fenstervertrieb GmbH</h3>
              <div class="mt-2 space-y-2">
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <span>Burscheider Str. 157, 51381 Leverkusen, Deutschland</span>
                </div>
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  <a href="tel:+49214XXXXXXX" class="hover:text-[#1c69d4]">+49 214 XXX XXXX</a>
                </div>
                <div class="flex items-start gap-2 text-sm text-base-500">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <a href="mailto:info@fenstervertrieb.de" class="hover:text-[#1c69d4]">info@fenstervertrieb.de</a>
                </div>
              </div>
            </div>

            <div class="pt-4 border-t border-base-200">
              <h3 class="text-sm font-medium text-base-900">Öffnungszeiten</h3>
              <div class="mt-2 text-sm text-base-500 space-y-1">
                <p>Montag – Freitag: 9:00 – 18:00</p>
                <p>Samstag: 10:00 – 14:00</p>
                <p>Sonntag: Geschlossen</p>
              </div>
            </div>

            <div class="pt-4 border-t border-base-200">
              <a
                href="https://wa.me/34968000000"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-[#25D366] text-white px-5 py-3 rounded text-sm font-medium hover:bg-[#1eb951] transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-2.96 2.89-2.96 7.007 0 4.107 2.987 7.697 3.382 8.222.297.397 4.052 6.198 9.318 8.708 1.303.562 2.317.896 3.11 1.149 1.304.415 2.497.354 3.437.214.979-.163 3.005-1.229 3.437-2.414.432-1.186.432-2.208.298-2.414-.134-.199-.397-.297-.694-.497z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.376 0-4.585-.796-6.366-2.142l-.444-.332-3.308 1.11 1.11-3.308-.332-.444A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
                Nachricht per WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>