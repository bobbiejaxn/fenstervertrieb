---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BreadcrumbJsonLd from "@/components/fundations/head/BreadcrumbJsonLd.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

// Parse price_from for JSON-LD (extract numeric value)
const priceMatch = product.data.price_from?.match(/([\d.,]+)/);
const priceNumber = priceMatch ? parseFloat(priceMatch[1].replace(/\./g, "").replace(",", ".")) : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.data.title,
  description: product.data.description,
  image: product.data.image.startsWith("/")
    ? `https://fenstervertrieb.debored.ai${product.data.image}`
    : product.data.image,
  brand: {
    "@type": "Brand",
    name: "Schüco",
  },
  manufacturer: {
    "@type": "Organization",
    name: "Schüco International KG",
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "EUR",
    ...(priceNumber !== null && { price: priceNumber }),
    availability: "https://schema.org/InStock",
    seller: {
      "@type": "Organization",
      name: "Fenstervertrieb GmbH",
      url: "https://fenstervertrieb.debored.ai"
    },
  },
};
---

<BaseLayout title={`${product.data.title} — Fenstervertrieb`} description={product.data.description?.slice(0, 160) || "Schüco Premium-Systeme"}>
  <BreadcrumbJsonLd items={[{ name: "Produkte", href: "/produkte" }, { name: product.data.title }]} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <a href="/produkte" class="text-sm text-gray-400 hover:text-white transition-colors">
        ← Zurück zu Produkte
      </a>
      <div class="mt-6 flex flex-col md:flex-row gap-8 md:gap-12">
        <div class="flex-1">
          <div class="aspect-[4/3] bg-gray-800 overflow-hidden rounded-lg">
            <img
              src={product.data.image}
              alt={product.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div class="flex-1">
          <div class="inline-block bg-[#1c69d4] text-white text-xs font-medium px-3 py-1 rounded mb-4">
            {product.data.category}
          </div>
          <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
            {product.data.title}
          </h1>
          {product.data.uwert && (
            <div class="mt-4 inline-block bg-white/10 text-white text-sm px-3 py-1 rounded">
              U-Wert: {product.data.uwert}
            </div>
          )}
          {product.data.price_from && (
            <div class="mt-4 inline-block bg-[#1c69d4] text-white text-sm px-3 py-1 rounded">
              {product.data.price_from}
            </div>
          )}
          <p class="mt-6 text-gray-300 leading-relaxed">
            {product.data.description}
          </p>

          <div class="mt-8">
            <h3 class="text-sm font-medium text-white uppercase tracking-wider mb-4">
              Highlights
            </h3>
            <ul class="space-y-2">
              {product.data.highlights.map((h: string) => (
                <li class="flex items-center gap-2 text-sm text-gray-300">
                  <svg class="w-4 h-4 text-[#1c69d4] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  {h}
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/kontakt"
              class="inline-block bg-[#1c69d4] text-white px-6 py-3 rounded text-sm font-medium hover:bg-[#1557b0] transition-colors"
            >
              Beratung anfragen
            </a>
            <a
              href="/foerderungen"
              class="inline-block border border-gray-500 text-gray-300 px-6 py-3 rounded text-sm font-medium hover:border-white hover:text-white transition-colors"
            >
              Förderungen prüfen
            </a>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  {product.data.features && product.data.features.length > 0 && (
    <section class="bg-white">
      <Wrapper variant="standard" class="py-16">
        <h2 class="font-serif italic text-2xl md:text-3xl text-base-900 font-medium">
          Technische Details
        </h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {product.data.features.map((f: string) => (
            <div class="flex items-start gap-3 p-4 border border-base-200 rounded-lg">
              <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-sm text-base-700">{f}</span>
            </div>
          ))}
        </div>
      </Wrapper>
    </section>
  )}
</BaseLayout>