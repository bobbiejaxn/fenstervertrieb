---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getCollection } from "astro:content";

const allProducts = await getCollection("products");

const categories = [
  { key: "Alle", label: "Alle" },
  { key: "Fenster", label: "Fenster" },
  { key: "Türen", label: "Türen" },
  { key: "Schiebesysteme", label: "Schiebesysteme" },
  { key: "Fassaden", label: "Fassaden" },
  { key: "Smart Home", label: "Smart Home" },
];

const categoryImages: Record<string, string> = {
  "Fenster": "/images/fenster-house.jpg",
  "Türen": "/images/tueren-interior.jpg",
  "Schiebesysteme": "/images/interior-office.jpg",
  "Fassaden": "/images/fenster-window.jpg",
  "Smart Home": "/images/fenster-house.jpg",
};
---

<BaseLayout title="Produkte — Fenstervertrieb" description="Premium-Aluminium- und PVC-Systeme von Schüco: Fenster, Türen, Schiebesysteme, Fassaden und Smart Home.">
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
        Unsere Produkte
      </h1>
      <p class="mt-4 text-gray-400 max-w-xl">
        Entdecken Sie das gesamte Sortiment an Schüco Systemen — von energieeffizienten Fenstern bis zu smarten Gebäudeautomatisierungen.
      </p>

      <!-- Category Filter -->
      <div id="category-filter" class="mt-8 flex flex-wrap gap-2">
        {categories.map((cat, i) => (
          <button
            data-category={cat.key}
            class={`filter-btn px-4 py-2 rounded text-sm font-medium transition-colors ${i === 0 ? "bg-[#1c69d4] text-white" : "bg-gray-800 text-gray-400 hover:bg-gray-700"}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </Wrapper>
  </section>

  <section class="bg-white">
    <Wrapper variant="standard" class="py-12">
      <div id="products-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {allProducts.map((product) => (
          <a
            href={`/produkte/${product.data.slug}`}
            data-product-category={product.data.category}
            class="product-card group block"
          >
            <div class="aspect-[4/3] bg-base-100 overflow-hidden rounded-lg">
              <img
                src={product.data.image}
                alt={product.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="mt-3">
              <div class="flex items-center gap-2">
                <h3 class="font-medium text-base-900">{product.data.title}</h3>
                {product.data.uwert && (
                  <span class="text-xs bg-[#1c69d4]/10 text-[#1c69d4] px-2 py-0.5 rounded">
                    {product.data.uwert}
                  </span>
                )}
              </div>
              <p class="text-xs text-base-500 mt-1">{product.data.category}</p>
              <p class="text-sm text-base-500 mt-2 line-clamp-2">{product.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<script type="module">
  const filterBtns = document.querySelectorAll(".filter-btn");
  const productCards = document.querySelectorAll(".product-card");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.getAttribute("data-category");

      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove("bg-[#1c69d4]", "text-white");
        b.classList.add("bg-gray-800", "text-gray-400");
      });
      btn.classList.remove("bg-gray-800", "text-gray-400");
      btn.classList.add("bg-[#1c69d4]", "text-white");

      // Filter products
      productCards.forEach((card) => {
        const cardCategory = card.getAttribute("data-product-category");
        if (category === "Alle" || cardCategory === category) {
          (card as HTMLElement).style.display = "";
        } else {
          (card as HTMLElement).style.display = "none";
        }
      });
    });
  });
</script>