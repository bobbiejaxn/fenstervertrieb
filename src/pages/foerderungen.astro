---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
        Förderungen
      </h1>
      <p class="mt-4 text-gray-400 max-w-xl">
        Nutzen Sie staatliche Förderprogramme für energieeffizientes Bauen und Renovieren in Spanien und Italien.
      </p>
    </Wrapper>
  </section>

  <!-- Spain CTE -->
  <section class="bg-white">
    <Wrapper variant="standard" class="py-16">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <div class="inline-block bg-[#1c69d4]/10 text-[#1c69d4] text-xs font-medium px-3 py-1 rounded mb-4">
            Spanien
          </div>
          <h2 class="font-serif italic text-2xl md:text-3xl text-base-900 font-medium">
            CTE — Código Técnico de la Edificación
          </h2>
          <div class="mt-6 space-y-4 text-sm text-base-500 leading-relaxed">
            <p>
              Der CTE (Código Técnico de la Edificación) ist die spanische Bauvorschrift, die energetische Mindestanforderungen an Gebäude definiert. Seit der Aktualisierung des HE1 (Energieeinsparung) im Jahr 2019 sind die Anforderungen deutlich verschärft worden.
            </p>
            <p>
              Schüco Aluminium-Fenstersysteme erfüllen und übertreffen die CTE-Anforderungen. Unsere Systeme erreichen U-Werte ab 0,64 W/m²K und sorgen dafür, dass Ihr Projekt nicht nur die gesetzlichen Vorgaben erfüllt, sondern auch von den verfügbaren Förderungen profitiert.
            </p>
          </div>

          <div class="mt-6">
            <h3 class="text-sm font-medium text-base-900 uppercase tracking-wider mb-3">
              Förderprogramme in Spanien
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">Programa de Rehabilitación Energética</div>
                  <div class="text-xs text-base-500">Bis zu 40% Zuschuss für energetische Sanierung</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">IDAE Förderungen</div>
                  <div class="text-xs text-base-500">Staatliche Förderung für energieeffiziente Fenster</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">Regionale Förderungen (z.B. Murcia)</div>
                  <div class="text-xs text-base-500">Zusätzliche Förderungen auf regionaler Ebene</div>
                </div>
              </li>
            </ul>
          </div>
        </div>
        <div class="aspect-[4/3] bg-base-100 rounded-lg overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80"
            alt="Energy efficient windows"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- Italy Ecobonus -->
  <section class="bg-gray-50">
    <Wrapper variant="standard" class="py-16">
      <div class="grid gap-12 md:grid-cols-2">
        <div class="aspect-[4/3] bg-base-100 rounded-lg overflow-hidden order-2 md:order-1">
          <img
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=80"
            alt="Italian architecture"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="order-1 md:order-2">
          <div class="inline-block bg-[#1c69d4]/10 text-[#1c69d4] text-xs font-medium px-3 py-1 rounded mb-4">
            Italien
          </div>
          <h2 class="font-serif italic text-2xl md:text-3xl text-base-900 font-medium">
            Ecobonus & Superbonus
          </h2>
          <div class="mt-6 space-y-4 text-sm text-base-500 leading-relaxed">
            <p>
              Italien bietet mit dem Ecobonus und dem Superbonus einige der attraktivsten Förderprogramme für energetische Sanierung in Europa. Fenster- und Türersetzungen sind förderfähig und können zu erheblichen Steuererleichterungen führen.
            </p>
            <p>
              Unsere Schüco Systeme erfüllen die Anforderungen für den Ecobonus (Detrazione fiscale) und können bei umfassenden Sanierungsprojekten auch in den Superbonus integriert werden.
            </p>
          </div>

          <div class="mt-6">
            <h3 class="text-sm font-medium text-base-900 uppercase tracking-wider mb-3">
              Förderprogramme in Italien
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">Ecobonus — 50% Detrazione</div>
                  <div class="text-xs text-base-500">Steuerabzug von 50% über 10 Jahre für Fensteraustausch</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">Superbonus — bis zu 110%</div>
                  <div class="text-xs text-base-500">Erweiterte Förderung bei ganzheitlicher Sanierung</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">Bonus Facciate</div>
                  <div class="text-xs text-base-500">Zusätzliche Förderung für Fassadensanierung inkl. Fenster</div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- CTA -->
  <section class="bg-[#1c69d4] text-white">
    <Wrapper variant="standard" class="py-16 text-center">
      <h2 class="font-serif italic text-2xl md:text-3xl font-medium">
        Förderberatung anfragen
      </h2>
      <p class="mt-4 text-blue-100 max-w-xl mx-auto text-sm">
        Wir beraten Sie gerne zu den verfügbaren Förderprogrammen in Ihrem Land und helfen bei der Antragstellung.
      </p>
      <div class="mt-8">
        <a
          href="/kontakt"
          class="inline-block bg-white text-[#1c69d4] px-6 py-3 rounded text-sm font-medium hover:bg-gray-100 transition-colors"
        >
          Kostenlos beraten lassen
        </a>
      </div>
    </Wrapper>
  </section>
</BaseLayout>