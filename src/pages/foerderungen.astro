---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BreadcrumbJsonLd from "@/components/fundations/head/BreadcrumbJsonLd.astro";
import FoerderungenFaqJsonLd from "@/components/fundations/head/FoerderungenFaqJsonLd.astro";
---

<BaseLayout title="Förderungen & Zuschüsse — Fenstervertrieb" description="Energieeffiziente Fenster werden staatlich gefördert. KfW, BAFA und Landesprogramme in Deutschland.">
  <BreadcrumbJsonLd items={[{ name: "Förderungen & Zuschüsse", href: "/foerderungen" }]} />
  <FoerderungenFaqJsonLd />
  <section class="bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="py-16 lg:py-24">
      <h1 class="font-serif italic text-3xl md:text-5xl font-medium tracking-tight">
        Förderungen
      </h1>
      <p class="mt-4 text-gray-400 max-w-xl">
        Nutzen Sie staatliche Förderprogramme für energieeffizientes Bauen und Renovieren in Deutschland.
      </p>
    </Wrapper>
  </section>

  <!-- KfW Förderung -->
  <section class="bg-white">
    <Wrapper variant="standard" class="py-16">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <div class="inline-block bg-[#1c69d4]/10 text-[#1c69d4] text-xs font-medium px-3 py-1 rounded mb-4">
            Deutschland
          </div>
          <h2 class="font-serif italic text-2xl md:text-3xl text-base-900 font-medium">
            KfW — Kreditanstalt für Wiederaufbau
          </h2>
          <div class="mt-6 space-y-4 text-sm text-base-500 leading-relaxed">
            <p>
              Die KfW fördert energieeffiziente Sanierungsmaßnahmen an Wohngebäuden. Der Austausch von Fenstern und Außentüren gehört zu den förderfähigen Maßnahmen im Rahmen des KfW-Programms 261 „Wohngebäude — Energieeffizient Sanieren".
            </p>
            <p>
              Schüco Aluminium-Fenstersysteme erfüllen und übertreffen die KfW-Anforderungen. Unsere Systeme erreichen U-Werte ab 0,64 W/m²K und sorgen dafür, dass Ihr Projekt nicht nur die gesetzlichen Vorgaben erfüllt, sondern auch von den verfügbaren Förderungen profitiert.
            </p>
          </div>

          <div class="mt-6">
            <h3 class="text-sm font-medium text-base-900 uppercase tracking-wider mb-3">
              KfW-Förderprogramme
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">KfW 261 — Energieeffizient Sanieren</div>
                  <div class="text-xs text-base-500">Zinsgünstige Kredite und Tilgungszuschüsse bis 120.000 € pro Wohneinheit</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">KfW 430 — Einzelmaßnahmen</div>
                  <div class="text-xs text-base-500">Tilgungszuschüsse für einzelne Sanierungsmaßnahmen wie Fensteraustausch</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">BEG — Bundesförderung für Energieeffizienz</div>
                  <div class="text-xs text-base-500">Zuschüsse über BAFA für Heizungs- und Fensteraustausch</div>
                </div>
              </li>
            </ul>
          </div>
        </div>
        <div class="aspect-[4/3] bg-base-100 rounded-lg overflow-hidden">
          <img
            src="/images/fenster-house.jpg"
            alt="Energy efficient windows"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- GEG / Energieeinsparverordnung -->
  <section class="bg-gray-50">
    <Wrapper variant="standard" class="py-16">
      <div class="grid gap-12 md:grid-cols-2">
        <div class="aspect-[4/3] bg-base-100 rounded-lg overflow-hidden order-2 md:order-1">
          <img
            src="/images/interior-office.jpg"
            alt="Modern interior with energy efficient windows"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="order-1 md:order-2">
          <div class="inline-block bg-[#1c69d4]/10 text-[#1c69d4] text-xs font-medium px-3 py-1 rounded mb-4">
            GEG 2024
          </div>
          <h2 class="font-serif italic text-2xl md:text-3xl text-base-900 font-medium">
            GEG — Gebäudeenergiegesetz
          </h2>
          <div class="mt-6 space-y-4 text-sm text-base-500 leading-relaxed">
            <p>
              Das Gebäudeenergiegesetz (GEG) definiert die energetischen Anforderungen an Neubau und Sanierung in Deutschland. Seit der Novelle 2024 gelten verschärfte U-Wert-Grenzen für Fensteraustausch: maximal 1,1 W/m²K bei Austausch, ab 2026 nur noch 0,95 W/m²K.
            </p>
            <p>
              Unsere Schüco Systeme erfüllen die Anforderungen des GEG 2024 und qualifizieren sich für alle verfügbaren Förderungen. Mit U-Werten ab 0,64 W/m²K liegen unsere Fenster deutlich unter den gesetzlichen Grenzwerten.
            </p>
          </div>

          <div class="mt-6">
            <h3 class="text-sm font-medium text-base-900 uppercase tracking-wider mb-3">
              Landesprogramme NRW
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">NRW.BANK Energieeffizienz</div>
                  <div class="text-xs text-base-500">Zinsgünstige Kredite für energieeffiziente Sanierung in Nordrhein-Westfalen</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">BAFA-BEG Zuschuss</div>
                  <div class="text-xs text-base-500">Bis zu 30% Zuschuss auf Material- und Einbaukosten für Fensteraustausch</div>
                </div>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#1c69d4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <div class="text-sm font-medium text-base-900">KfW-Effizienzhaus</div>
                  <div class="text-xs text-base-500">Tilgungszuschüsse bis zu 35% bei Erreichen eines Effizienzhaus-Standards</div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- Energieeffizienz -->
  <section class="bg-white">
    <Wrapper variant="standard" class="py-16">
      <div class="max-w-3xl mx-auto">
        <div class="inline-block bg-[#1c69d4]/10 text-[#1c69d4] text-xs font-medium px-3 py-1 rounded mb-4">
          Energieeffizienz
        </div>
        <h2 class="font-serif italic text-2xl md:text-3xl text-base-900 font-medium">
          Warum Energieeffizienz für Förderungen entscheidend ist
        </h2>
        <div class="mt-6 space-y-4 text-sm text-base-500 leading-relaxed">
          <p>
            Energieeffizienz ist der Schlüssel zu staatlichen Förderprogrammen in Deutschland. Nur Fenster und Türen, die die strengen U-Wert-Grenzen einhalten, qualifizieren sich für Zuschüsse und Tilgungsfreistellungen.
          </p>
          <p>
            Das GEG 2024 verlangt bei Fensteraustausch einen maximalen U-Wert von <strong>1,1 W/m²K</strong>, ab 2026 nur noch <strong>0,95 W/m²K</strong>. Für die besten KfW-Förderquoten sollten Fenster einen U-Wert von unter <strong>0,8 W/m²K</strong> erreichen — unsere Schüco AWS-Serien erfüllen diese Vorgabe mühelos.
          </p>
          <p>
            Für den BAFA-BEG-Zuschuss muss der Fensteraustausch den nachweislichen Energiebedarf des Gebäudes senken. Unsere Schüco Systeme mit U-Werten ab <strong>0,64 W/m²K</strong> übertreffen diese Grenzen und maximieren Ihren Förderanspruch — bis zu 30% Zuschuss auf die Gesamtkosten.
          </p>
        </div>
      </div>
    </Wrapper>
  </section>

  <!-- CTA -->
  <section class="bg-[#1c69d4] text-white">
    <Wrapper variant="standard" class="py-16 text-center">
      <h2 class="font-serif italic text-2xl md:text-3xl font-medium">
        Förderberatung anfragen
      </h2>
      <p class="mt-4 text-blue-100 max-w-xl mx-auto text-sm">
        Wir beraten Sie gerne zu den verfügbaren Förderprogrammen in Deutschland und helfen bei der Antragstellung.
      </p>
      <div class="mt-8">
        <a
          href="/kontakt"
          class="inline-block bg-white text-[#1c69d4] px-6 py-3 rounded text-sm font-medium hover:bg-gray-100 transition-colors"
        >
          Kostenlos beraten lassen
        </a>
      </div>
    </Wrapper>
  </section>
</BaseLayout>