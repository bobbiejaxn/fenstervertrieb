---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

// Return 404 status code
Astro.response.status = 404;
---

<BaseLayout hideNav={true} hideFooter={true} title="404 — Seite nicht gefunden" description="Die angeforderte Seite existiert nicht.">
  <div class="flex flex-col items-center justify-center min-h-svh bg-[#0a0a0a] text-white">
    <Wrapper variant="standard" class="text-center py-24">
      <div class="text-8xl font-serif italic font-medium text-[#1c69d4]">404</div>
      <h1 class="mt-4 font-serif italic text-2xl md:text-3xl font-medium">
        Seite nicht gefunden
      </h1>
      <p class="mt-4 text-gray-400 max-w-md mx-auto text-sm">
        Die angeforderte Seite existiert nicht. Möglicherweise wurde sie verschoben oder gelöscht.
      </p>
      <a
        href="/"
        class="mt-8 inline-block bg-[#1c69d4] text-white px-6 py-3 rounded text-sm font-medium hover:bg-[#1557b0] transition-colors"
      >
        Zur Startseite
      </a>
    </Wrapper>
  </div>
</BaseLayout>